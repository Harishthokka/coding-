import java.util.Scanner;
class Main {
   public static void main(String[] args) {
    Scanner sc=new Scanner(System.in);
    int f=sc.nextInt();
    int l=sc.nextInt();
    boolean found=false;
    for(int i=f;i<=l;i++){
        if(i%400==0 || (i%100!=0 && i%4==0)){
            System.out.println(i);
            found=true;
        }
    }
    if(found==false){
        System.out.println(-1);
    }     
   }
}
